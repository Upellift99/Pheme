# --- Huawei HiLink CPE ---
HUAWEI_HOST=192.168.8.1
HUAWEI_USER=admin
HUAWEI_PASSWORD=change-me-cpe-password

# --- Matrix ---
MATRIX_HOMESERVER=https://matrix.example.org
MATRIX_TOKEN=syt_examplebottoken_changeme
MATRIX_USER_ID=@phemebot:example.org
MATRIX_ROOM_ID=!abcdefghijklmnop:example.org

# --- Behaviour ---
# Seconds between inbox polls.
POLL_INTERVAL=60
# SQLite state file (inside the mounted /data volume).
STATE_DB=/data/state.db
# Mark relayed SMS as read on the CPE (default false: do not mutate CPE state).
MARK_AS_READ=false
# Delete relayed SMS from the CPE after relaying (default false).
DELETE_AFTER_RELAY=false
# Set false for a read-only bridge (inbound SMS -> Matrix only, no sending).
ALLOW_OUTBOUND=true
# Logging verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
